# ===== Neon (Database) =====
# Neon Console → プロジェクトの接続文字列をコピー
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ===== Neon Auth (認証 / Better Auth) =====
# Neon Console で Neon Auth を有効化すると取得できる Base URL
NEON_AUTH_BASE_URL="https://ep-xxxx.neonauth.REGION.aws.neon.tech/DBNAME/auth"
# セッションCookie署名用シークレット（32文字以上）。生成: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="REPLACE_WITH_A_32+_CHARACTER_RANDOM_SECRET"

# ===== Google Gemini =====
GEMINI_API_KEY="your_gemini_api_key"
